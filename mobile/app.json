{
  "expo": {
    "name": "Medical Consultation",
    "slug": "medical-consultation-mobile",
    "scheme": "medconsult",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-secure-store"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.medconsult.mobile"
    },
    "android": {
      "package": "com.medconsult.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0b1b27"
      }
    },
    "extra": {
      "apiUrl": "http://localhost:5001/api/v1"
    }
  }
}

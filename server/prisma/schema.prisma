generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
  PATIENT
}

enum UserStatus {
  ACTIVE
  PENDING
  REJECTED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PostStatus {
  PUBLISHED
  DRAFT
}

enum ConsultationStatus {
  PENDING
  ACCEPTED
  COMPLETED
  CANCELLED
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}

enum MessageStatus {
  SENT
  DELIVERED
  SEEN
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum TreatmentPlanStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum NotificationType {
  GENERIC
  TREATMENT_PLAN_CREATED
  TREATMENT_PLAN_UPDATED
  APPOINTMENT_BOOKED
  CONSULTATION_ACCEPTED
  FOLLOW_UP_SUBMITTED
  DOCTOR_APPROVED
  GROUP_POST_PUBLISHED
  CHAT_MESSAGE
  CONVERSATION_CREATED
  MESSAGE_SEEN
}

enum PresenceStatus {
  ONLINE
  OFFLINE
}

enum GroupVisibility {
  PUBLIC
  PRIVATE
}

model User {
  id                       String                  @id @default(cuid())
  fullName                 String
  email                    String                  @unique
  password                 String
  profileImageUrl          String?
  role                     Role
  status                   UserStatus              @default(ACTIVE)
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  patientProfile           PatientProfile?
  doctorProfile            DoctorProfile?
  notifications            Notification[]
  conversationParticipants ConversationParticipant[]
  messages                 Message[]
  presence                 UserPresence?
}

model PatientProfile {
  id                 String            @id @default(cuid())
  userId             String            @unique
  gender             String
  dateOfBirth        DateTime
  city               String?
  region             String?
  bloodType          String?
  chronicDiseases    String?
  currentMedications String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  consultations      Consultation[]
  conversations      Conversation[]
  appointments       Appointment[]
  treatmentPlans     TreatmentPlan[]
  followUps          FollowUpEntry[]
  medicalRecord      MedicalRecord?
  reviews            Review[]
  groupMemberships   GroupMembership[]
}

model DoctorProfile {
  id                String         @id @default(cuid())
  userId            String         @unique
  specialization    String
  city              String?
  region            String?
  yearsOfExperience Int
  bio               String
  licenseNumber     String         @unique
  consultationFee   Int?
  supportsOnline    Boolean        @default(true)
  supportsInPerson  Boolean        @default(true)
  isAvailableNow    Boolean        @default(false)
  isVerified        Boolean        @default(false)
  approvalStatus    ApprovalStatus @default(PENDING)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts             Post[]
  consultations     Consultation[]
  conversations     Conversation[]
  appointments      Appointment[]
  treatmentPlans    TreatmentPlan[]
  reviews           Review[]
  groups            Group[]
  groupPosts        GroupPost[]
}

model Post {
  id             String        @id @default(cuid())
  doctorId       String
  title          String
  content        String
  specialization String
  status         PostStatus    @default(PUBLISHED)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  doctor         DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([specialization])
}

model Consultation {
  id             String             @id @default(cuid())
  patientId      String
  doctorId       String
  subject        String
  description    String
  doctorResponse String?
  status         ConsultationStatus @default(PENDING)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  patient        PatientProfile     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor         DoctorProfile      @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  conversation   Conversation?
  treatmentPlans TreatmentPlan[]
  reviews        Review[]

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
}

model Conversation {
  id                String                    @id @default(cuid())
  consultationId    String                    @unique
  patientId         String
  doctorId          String
  lastMessageAt     DateTime?
  lastMessagePreview String?
  lastMessageType   MessageType?
  lastMessageStatus MessageStatus?
  lastMessageSenderId String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  consultation      Consultation              @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  patient           PatientProfile            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor            DoctorProfile             @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  participants      ConversationParticipant[]
  messages          Message[]
  notifications     Notification[]

  @@index([patientId, lastMessageAt])
  @@index([doctorId, lastMessageAt])
  @@index([lastMessageAt])
}

model ConversationParticipant {
  id             String        @id @default(cuid())
  conversationId String
  userId         String
  role           Role
  unreadCount    Int           @default(0)
  lastReadAt     DateTime?
  joinedAt       DateTime      @default(now())
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, unreadCount])
  @@index([userId, updatedAt])
}

model Message {
  id             String             @id @default(cuid())
  conversationId String
  senderId       String
  body           String?
  type           MessageType        @default(TEXT)
  status         MessageStatus      @default(SENT)
  deliveredAt    DateTime?
  seenAt         DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  conversation   Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User               @relation(fields: [senderId], references: [id], onDelete: Cascade)
  attachments    MessageAttachment[]
  notifications  Notification[]

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
  @@index([status, createdAt])
}

model MessageAttachment {
  id           String   @id @default(cuid())
  messageId    String
  storageKey   String   @unique
  originalName String
  mimeType     String
  sizeBytes    Int
  fileExtension String?
  createdAt    DateTime @default(now())
  message      Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model Appointment {
  id              String            @id @default(cuid())
  patientId       String
  doctorId        String
  appointmentDate DateTime
  notes           String?
  status          AppointmentStatus @default(SCHEDULED)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  patient         PatientProfile    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor          DoctorProfile     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  reviews         Review[]

  @@index([patientId])
  @@index([doctorId])
  @@index([appointmentDate])
}

model TreatmentPlan {
  id               String              @id @default(cuid())
  patientId        String
  doctorId         String
  consultationId   String?
  title            String
  diagnosisSummary String
  instructions     String
  startDate        DateTime
  endDate          DateTime
  status           TreatmentPlanStatus @default(ACTIVE)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  patient          PatientProfile      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor           DoctorProfile       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  consultation     Consultation?       @relation(fields: [consultationId], references: [id], onDelete: SetNull)
  medications      Medication[]
  followUps        FollowUpEntry[]

  @@index([patientId])
  @@index([doctorId])
  @@index([consultationId])
  @@index([status])
}

model Medication {
  id              String        @id @default(cuid())
  treatmentPlanId String
  medicationName  String
  dosage          String
  frequency       String
  durationInDays  Int
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  treatmentPlan   TreatmentPlan @relation(fields: [treatmentPlanId], references: [id], onDelete: Cascade)

  @@index([treatmentPlanId])
}

model FollowUpEntry {
  id             String        @id @default(cuid())
  treatmentPlanId String
  patientId      String
  symptomsStatus String
  painLevel      Int?
  sideEffects    String?
  notes          String?
  doctorNote     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  treatmentPlan  TreatmentPlan @relation(fields: [treatmentPlanId], references: [id], onDelete: Cascade)
  patient        PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([treatmentPlanId])
  @@index([patientId])
  @@index([createdAt])
}

model MedicalRecord {
  id               String         @id @default(cuid())
  patientId        String         @unique
  allergies        String?
  chronicDiseases  String?
  surgeriesHistory String?
  familyHistory    String?
  lifestyleNotes   String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  patient          PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Review {
  id             String         @id @default(cuid())
  patientId      String
  doctorId       String
  consultationId String?
  appointmentId  String?
  rating         Int
  comment        String?
  createdAt      DateTime       @default(now())
  patient        PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor         DoctorProfile  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  consultation   Consultation?  @relation(fields: [consultationId], references: [id], onDelete: SetNull)
  appointment    Appointment?   @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([doctorId])
  @@index([createdAt])
  @@unique([patientId, consultationId])
  @@unique([patientId, appointmentId])
}

model Notification {
  id             String           @id @default(cuid())
  userId         String
  conversationId String?
  messageId      String?
  type           NotificationType @default(GENERIC)
  title          String
  message        String
  entityType     String?
  entityId       String?
  metadata       Json?
  isRead         Boolean          @default(false)
  readAt         DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @default(now()) @updatedAt
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation?    @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  relatedMessage Message?         @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId, isRead, createdAt])
  @@index([conversationId, createdAt])
  @@index([messageId, createdAt])
}

model UserPresence {
  id          String         @id @default(cuid())
  userId      String         @unique
  status      PresenceStatus @default(OFFLINE)
  socketCount Int            @default(0)
  lastSeenAt  DateTime?
  lastActiveAt DateTime      @default(now())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, lastActiveAt])
}

model Group {
  id                String          @id @default(cuid())
  name              String
  description       String
  category          String
  visibility        GroupVisibility @default(PUBLIC)
  createdByDoctorId String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  createdByDoctor   DoctorProfile   @relation(fields: [createdByDoctorId], references: [id], onDelete: Cascade)
  memberships       GroupMembership[]
  posts             GroupPost[]

  @@index([createdByDoctorId])
  @@index([visibility])
  @@index([category])
}

model GroupMembership {
  id        String         @id @default(cuid())
  groupId   String
  patientId String
  joinedAt  DateTime       @default(now())
  group     Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([groupId, patientId])
  @@index([patientId])
}

model GroupPost {
  id        String        @id @default(cuid())
  groupId   String
  doctorId  String
  title     String
  content   String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  group     Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  doctor    DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([doctorId])
}
